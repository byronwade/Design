{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/byronwade/Design/.design/schema/project.schema.json",
  "title": "Installed Design Contract Project Configuration",
  "type": "object",
  "required": ["schemaVersion", "targets"],
  "properties": {
    "$schema": {"type": "string"},
    "schemaVersion": {"const": 1},
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "profile"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
          "profile": {"type": "string", "minLength": 1},
          "description": {"type": "string"},
          "root": {"type": "string"},
          "default": {"type": "boolean"},
          "overrides": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
        },
        "additionalProperties": false
      }
    },
    "overrides": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "adapters": {"type": "array", "items": {"enum": ["codex", "claude", "copilot"]}, "uniqueItems": true}
  },
  "additionalProperties": false
}
