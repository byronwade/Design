{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/byronwade/Design/.design/schema/rules.schema.json",
  "title": "Design Contract Quality Rules",
  "type": "object",
  "required": ["schemaVersion", "rules"],
  "properties": {
    "schemaVersion": {"const": 1},
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "severity", "category", "requirement"],
        "properties": {
          "id": {"type": "string", "pattern": "^DS-[A-Z0-9]+-[0-9]{3}$"},
          "severity": {"enum": ["error", "warning", "info"]},
          "category": {"type": "string", "minLength": 1},
          "requirement": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
