{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/byronwade/Design/.design/schema/manifest.schema.json",
  "title": "Design Engine Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "packageVersion",
    "googleDesignMd",
    "authority",
    "requiredInEveryProfile",
    "layers",
    "bundles",
    "profiles",
    "qualityRules",
    "sourceDocuments",
    "sourceArchives"
  ],
  "properties": {
    "$schema": {"type": "string"},
    "schemaVersion": {"const": 1},
    "packageVersion": {"type": "string", "minLength": 1},
    "googleDesignMd": {
      "type": "object",
      "required": ["status", "cliPackage", "cliVersion", "file", "schemaExtensionPolicy"],
      "properties": {
        "status": {"type": "string"},
        "cliPackage": {"type": "string"},
        "cliVersion": {"type": "string"},
        "file": {"type": "string"},
        "schemaExtensionPolicy": {"type": "string"}
      },
      "additionalProperties": false
    },
    "authority": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "requiredInEveryProfile": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "layers": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["file", "role", "extends"],
        "properties": {
          "file": {"type": "string", "minLength": 1},
          "role": {"type": "string", "minLength": 1},
          "extends": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
        },
        "additionalProperties": false
      }
    },
    "bundles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true}
    },
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["description", "bundles", "roots"],
        "properties": {
          "description": {"type": "string", "minLength": 1},
          "bundles": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
          "roots": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
          "composite": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "qualityRules": {"type": "string", "minLength": 1},
    "sourceDocuments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["file", "authority", "sha256"],
        "properties": {
          "file": {"type": "string", "minLength": 1},
          "authority": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        },
        "additionalProperties": false
      }
    },
    "sourceArchives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "index", "parts", "originalSha256"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "index": {"type": "string", "minLength": 1},
          "parts": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
          "originalSha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
