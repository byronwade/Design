{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/byronwade/Design/.design/schema/manifest.schema.json",
  "title": "Design Contract Manifest",
  "type": "object",
  "required": ["schemaVersion", "packageVersion", "googleDesignMd", "authority", "requiredInEveryProfile", "layers", "bundles", "profiles", "projectDocumentDefaults", "projectOwnedFiles", "qualityRules"],
  "properties": {
    "$schema": {"type": "string"},
    "schemaVersion": {"const": 1},
    "packageVersion": {"type": "string", "minLength": 1},
    "googleDesignMd": {
      "type": "object",
      "required": ["status", "cliPackage", "cliVersion", "file", "schemaExtensionPolicy"],
      "properties": {
        "status": {"type": "string"},
        "cliPackage": {"type": "string"},
        "cliVersion": {"type": "string"},
        "file": {"type": "string"},
        "schemaExtensionPolicy": {"type": "string"}
      },
      "additionalProperties": false
    },
    "authority": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "requiredInEveryProfile": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "layers": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["file", "role", "extends"],
        "properties": {
          "file": {"type": "string"},
          "role": {"type": "string"},
          "extends": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
        },
        "additionalProperties": false
      }
    },
    "bundles": {"type": "object", "additionalProperties": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}},
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["description", "bundles", "roots"],
        "properties": {
          "description": {"type": "string"},
          "bundles": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "roots": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "composite": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "projectDocumentDefaults": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "projectOwnedFiles": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "qualityRules": {"type": "string"},
    "sourceDocuments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "authority", "sha256"],
        "properties": {
          "file": {"type": "string"},
          "authority": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        },
        "additionalProperties": false
      }
    },
    "sourceArchives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "index", "parts", "originalSha256"],
        "properties": {
          "id": {"type": "string"},
          "index": {"type": "string"},
          "parts": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "originalSha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        },
        "additionalProperties": false
      }
    },
    "generatedDirectory": {"type": "string"}
  },
  "additionalProperties": false
}
