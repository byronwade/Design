{
  "schemaVersion": 1,
  "component": "warm-success-status-badge",
  "description": "A compact warm success status badge for an approved review state, with dot, label, and focus-visible treatment.",
  "targetAccuracy": 99,
  "anatomy": [
    "badge.root",
    "badge.status-dot",
    "badge.label",
    "badge.focus-ring"
  ],
  "tokens": {
    "height": 24,
    "paddingInline": 8,
    "gap": 4,
    "radius": 999,
    "background": "#E8F2E7",
    "foreground": "#356548",
    "border": "rgba(67, 52, 38, 0.15)",
    "dotColor": "#356548",
    "fontFamily": "Inter",
    "fontWeight": 500,
    "labelSize": 12,
    "dotSize": 6
  },
  "states": {
    "hover": {
      "background": "#E8F2E7",
      "border": "rgba(67, 52, 38, 0.22)"
    },
    "focusVisible": {
      "outlineWidth": 2,
      "outlineColor": "#7D4936",
      "outlineOffset": 2
    },
    "disabled": {
      "background": "#FAF5EC",
      "foreground": "#766E65",
      "opacity": 0.72
    }
  },
  "content": {
    "label": "Approved",
    "ariaLabel": "Status: Approved"
  }
}
