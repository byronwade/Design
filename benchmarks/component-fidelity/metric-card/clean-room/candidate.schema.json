{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate",
    "track",
    "generatedBy",
    "cleanRoom",
    "allowedInputs",
    "provenance",
    "anatomy",
    "tokens",
    "states",
    "content"
  ],
  "properties": {
    "candidate": { "type": "string" },
    "track": { "enum": ["baseline", "plain-prompt", "contract-plus-skills"] },
    "generatedBy": { "type": "string" },
    "cleanRoom": { "const": true },
    "allowedInputs": { "type": "array", "items": { "type": "string" } },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runId",
        "model",
        "operator",
        "generatedAt",
        "targetAccess",
        "promptSha256",
        "allowedInputsSha256",
        "allowedInputFiles",
        "cleanRoomAttestation"
      ],
      "properties": {
        "runId": { "type": "string" },
        "model": { "type": "string" },
        "operator": { "type": "string" },
        "generatedAt": { "type": "string" },
        "targetAccess": { "const": false },
        "promptSha256": { "type": "string" },
        "allowedInputsSha256": { "type": "string" },
        "allowedInputFiles": { "type": "array", "items": { "type": "string" } },
        "cleanRoomAttestation": { "type": "string" }
      }
    },
    "anatomy": {
      "type": "array",
      "items": {
        "enum": [
          "metric.root",
          "metric.header",
          "metric.label",
          "metric.menu-trigger",
          "metric.value",
          "metric.delta",
          "metric.caption",
          "metric.sparkline",
          "metric.status-dot",
          "metric.focus-ring"
        ]
      }
    },
    "tokens": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "padding",
        "gap",
        "radius",
        "background",
        "foreground",
        "border",
        "mutedForeground",
        "accent",
        "positive",
        "warning",
        "shadow",
        "fontFamily",
        "labelWeight",
        "valueWeight",
        "labelSize",
        "valueSize",
        "deltaSize",
        "captionSize",
        "sparklineHeight"
      ],
      "properties": {
        "width": { "type": "number" },
        "padding": { "type": "number" },
        "gap": { "type": "number" },
        "radius": { "type": "number" },
        "background": { "type": "string", "pattern": "^#[a-fA-F0-9]{6}$" },
        "foreground": { "type": "string", "pattern": "^#[a-fA-F0-9]{6}$" },
        "border": { "type": "string", "pattern": "^#[a-fA-F0-9]{6}$" },
        "mutedForeground": { "type": "string", "pattern": "^#[a-fA-F0-9]{6}$" },
        "accent": { "type": "string", "pattern": "^#[a-fA-F0-9]{6}$" },
        "positive": { "type": "string", "pattern": "^#[a-fA-F0-9]{6}$" },
        "warning": { "type": "string", "pattern": "^#[a-fA-F0-9]{6}$" },
        "shadow": { "type": "string" },
        "fontFamily": { "type": "string" },
        "labelWeight": { "type": "number" },
        "valueWeight": { "type": "number" },
        "labelSize": { "type": "number" },
        "valueSize": { "type": "number" },
        "deltaSize": { "type": "number" },
        "captionSize": { "type": "number" },
        "sparklineHeight": { "type": "number" }
      }
    },
    "states": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hover", "focusVisible", "selected", "stale"],
      "properties": {
        "hover": {
          "type": "object",
          "additionalProperties": false,
          "required": ["background", "border", "shadow"],
          "properties": {
            "background": { "type": "string", "pattern": "^#[a-fA-F0-9]{6}$" },
            "border": { "type": "string", "pattern": "^#[a-fA-F0-9]{6}$" },
            "shadow": { "type": "string" }
          }
        },
        "focusVisible": {
          "type": "object",
          "additionalProperties": false,
          "required": ["outlineWidth", "outlineColor", "outlineOffset"],
          "properties": {
            "outlineWidth": { "type": "number" },
            "outlineColor": { "type": "string", "pattern": "^#[a-fA-F0-9]{6}$" },
            "outlineOffset": { "type": "number" }
          }
        },
        "selected": {
          "type": "object",
          "additionalProperties": false,
          "required": ["border", "background"],
          "properties": {
            "border": { "type": "string", "pattern": "^#[a-fA-F0-9]{6}$" },
            "background": { "type": "string", "pattern": "^#[a-fA-F0-9]{6}$" }
          }
        },
        "stale": {
          "type": "object",
          "additionalProperties": false,
          "required": ["statusColor", "caption", "opacity"],
          "properties": {
            "statusColor": { "type": "string", "pattern": "^#[a-fA-F0-9]{6}$" },
            "caption": { "type": "string" },
            "opacity": { "type": "number" }
          }
        }
      }
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "value", "delta", "caption", "menuLabel", "staleCaption"],
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "string" },
        "delta": { "type": "string" },
        "caption": { "type": "string" },
        "menuLabel": { "type": "string" },
        "staleCaption": { "type": "string" }
      }
    }
  }
}
