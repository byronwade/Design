---
import SiteHeader from '../components/SiteHeader.astro';
import Icon from '../components/Icon.astro';
import { siteTokenCss } from '../data/site-tokens';
import '../styles/global.css';
const { title = 'Design Contract', description = 'A compact contract browser for design systems, references, and agent-ready rules.', active = '', theme = '' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://design.byronwade.com');
const isHomepage = Astro.url.pathname === '/';
---
<!doctype html>
<html lang="en">
  <head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width" /><meta name="generator" content={Astro.generator} /><meta name="theme-color" content="#111111" /><title>{title}</title><meta name="description" content={description} /><meta name="robots" content="index,follow" /><link rel="canonical" href={canonical} /><link rel="sitemap" type="application/xml" href="/sitemap.xml" /><meta property="og:type" content="website" /><meta property="og:site_name" content="Design Contract" /><meta property="og:title" content={title} /><meta property="og:description" content={description} /><meta property="og:url" content={canonical} /><meta name="twitter:card" content="summary" />{isHomepage ? <style set:html={siteTokenCss}></style> : <link rel="stylesheet" href="/design-tokens.css" />}<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'%3E%3Crect width='24' height='24' rx='6' fill='%23111111'/%3E%3Cpath d='M6 8h12v2H6zm0 4h9v2H6z' fill='white'/%3E%3C/svg%3E" /></head>
  <body class:list={[theme && `theme-${theme}`]}>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <SiteHeader active={active} />
    <main id="main-content"><slot /></main>
    <footer class="site-footer">
      <div class="footer-main">
        <a class="wordmark footer-wordmark" href="/"><span class="wordmark-mark" aria-hidden="true"><i></i><i></i><i></i></span><span>Design Contract</span></a>
        <p>Project-owned design truth, compiled for the work in front of the AI.</p>
      </div>
      <div class="footer-links"><a href="/contracts/">Contracts</a><a href="/docs/">Docs</a><a href="https://github.com/byronwade/Design" target="_blank" rel="noreferrer">Source <Icon name="external" size={13} /></a></div>
      <div class="footer-note"><span>Open source</span><code>@byronwade/design-contract</code></div>
    </footer>
  </body>
</html>
