---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Icon from '../../components/Icon.astro';

const fields = [
  ['slug', 'Stable URL name', 'Lowercase, short, and safe to keep forever.'],
  ['title', 'System name', 'What a person should recognize in a gallery.'],
  ['author', 'Person or team', 'Give the work a clear owner.'],
  ['surface', 'Primary surface', 'web app, web marketing, mobile, or desktop.'],
  ['summary', 'One-sentence thesis', 'Explain the system’s point of view, not its feature list.'],
  ['tags', 'Search vocabulary', 'Use a small set of specific, useful terms.'],
  ['screens', 'Surface studies', 'Three local context views; each can later point to a real asset and alt text.'],
  ['notes', 'Design decisions', 'Three concise observations about what the system makes visible.'],
];

const example = JSON.stringify({
  slug: 'your-system',
  title: 'Your System',
  author: 'Your name or team',
  kind: 'Curated example',
  surface: 'web app',
  summary: 'A one-sentence description of the system’s point of view.',
  tags: ['calm', 'operational', 'accessible'],
  preview: 'warm',
  screens: [
    { label: '01 / Shell', title: 'The working frame', caption: 'Describe the first context view.', preview: 'warm' },
    { label: '02 / Detail', title: 'Context remains adjacent', caption: 'Describe the second context view.', preview: 'blue', asset: '/showcase/your-system/detail.webp', alt: 'Describe the local screenshot.' },
    { label: '03 / State', title: 'The consequence is clear', caption: 'Describe the third context view.', preview: 'green' },
  ],
  source: 'website/src/data/showcase.ts',
  notes: ['A decision this system makes visible.', 'A behavior that preserves trust or continuity.', 'A detail that would help another designer learn from it.'],
}, null, 2);
---
<SiteLayout title="Submit a system — Showcase / Design index" description="The local open-source contribution kit for adding a design system to the Design / index showcase." active="showcase">
  <section class="submit-hero page-frame"><div><p class="eyebrow"><span class="eyebrow-rule"></span> Open source contribution</p><h1>Share the system<br /><em>behind the surface.</em></h1><p>A good showcase entry gives another designer enough context to learn from a real system. The local workflow is live now; account-based submission and moderation will arrive with the backend.</p></div><div class="submit-status"><span>Contribution status</span><strong>Local workflow live</strong><small>backend / later<br />record contract / now</small></div></section>
  <section class="submit-layout page-frame"><aside class="submit-sidebar"><span>Submission kit</span><a href="#contract">Record shape</a><a href="#example">Example</a><a href="#checklist">Before opening a PR</a><a href="#future">Future backend</a></aside><article class="submit-content"><section id="contract"><p class="eyebrow"><span class="eyebrow-rule"></span> Record shape</p><h2>One record, enough context.</h2><p class="submit-intro">Add a typed record to <code>website/src/data/showcase.ts</code>. The public page, gallery, search index, source link, and future API seam all read the same shape.</p><div class="submit-fields">{fields.map(([name, label, description]) => <div><code>{name}</code><div><strong>{label}</strong><p>{description}</p></div></div>)}</div></section><section id="example" class="submit-section"><p class="eyebrow"><span class="eyebrow-rule"></span> Start from this</p><h2>A useful seed record.</h2><pre><code>{example}</code></pre><a class="text-link" href="https://github.com/byronwade/Design/blob/main/website/src/data/showcase.ts" target="_blank" rel="noreferrer">Open the local data file <Icon name="external" size={14} /></a></section><section id="checklist" class="submit-section"><p class="eyebrow"><span class="eyebrow-rule"></span> Review before sharing</p><h2>Show the decision, not only the polish.</h2><div class="submit-checklist"><p><span>01</span>Use a stable slug and a title that makes sense out of context.</p><p><span>02</span>Describe the audience, surface, and point of view in plain language.</p><p><span>03</span>Give the gallery three context views and useful captions; add real local assets only when they are ready.</p><p><span>04</span>Run <code>npm run check</code> and inspect the generated route in a browser.</p></div></section><section id="future" class="submit-section submit-future"><p class="eyebrow"><span class="eyebrow-rule"></span> Backend boundary</p><h2>The public record will stay readable.</h2><p>When submissions become persistent, accounts, moderation, assets, and permissions will sit around this public reading record. They will not replace the stable slug, structured screens, notes, or source-oriented page.</p><a class="button button-secondary" href="/docs/#contribute">Read the content model <Icon name="arrow" size={15} /></a></section></article></section>
</SiteLayout>
