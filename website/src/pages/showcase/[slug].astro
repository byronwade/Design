---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Icon from '../../components/Icon.astro';
import ShowcaseGallery from '../../components/ShowcaseGallery.astro';
import { showcase } from '../../data/showcase';
export function getStaticPaths() { return showcase.map((item) => ({ params: { slug: item.slug }, props: { item } })); }
const { item } = Astro.props;
const index = showcase.findIndex((entry) => entry.slug === item.slug);
const previous = showcase[index - 1];
const next = showcase[index + 1];
---
<SiteLayout title={`${item.title} — Showcase / Design index`} description={item.summary} active="showcase">
  <div class="showcase-detail page-frame"><a class="back-link" href="/showcase/"><Icon name="arrow" size={15} /> Back to showcase</a><div class="showcase-detail-breadcrumb"><span>{item.kind}</span><span>/</span><span>{item.surface}</span></div><header class="showcase-detail-header"><p class="eyebrow"><span class="eyebrow-rule"></span> {item.author}</p><h1>{item.title}</h1><p>{item.summary}</p><div class="detail-tags">{item.tags.map((tag) => <span>{tag}</span>)}</div></header><ShowcaseGallery screens={item.screens} /><section class="showcase-notes"><div><p class="eyebrow"><span class="eyebrow-rule"></span> Design notes</p><h2>What this system makes visible.</h2></div><div class="showcase-note-list">{item.notes.map((note, index) => <p><span>0{index + 1}</span>{note}</p>)}</div></section><section class="showcase-source"><div><p class="eyebrow"><span class="eyebrow-rule"></span> Local record</p><p>This showcase entry is authored locally and intentionally transport-neutral. Its screens can remain local previews today or become uploaded assets later without changing the stable route or reading contract.</p></div><a class="button button-secondary" href={`https://github.com/byronwade/Design/blob/main/${item.source}`} target="_blank" rel="noreferrer">Open source record <Icon name="external" size={15} /></a></section><nav class="detail-pagination" aria-label="Adjacent showcase entries">{previous ? <a href={`/showcase/${previous.slug}/`}><small>Previous</small><strong><Icon name="arrow" size={15} /> {previous.title}</strong></a> : <span></span>}{next ? <a class="next-topic" href={`/showcase/${next.slug}/`}><small>Next</small><strong>{next.title} <Icon name="arrow" size={15} /></strong></a> : <span></span>}</nav></div>
</SiteLayout>
