---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Icon from '../../components/Icon.astro';
import ContractPreview from '../../components/ContractPreview.astro';
import ContractDemo from '../../components/ContractDemo.astro';
import Badge from '../../components/ui/Badge.astro';
import Button from '../../components/ui/Button.astro';
import Surface from '../../components/ui/Surface.astro';
import { contractProjects, contractReferences } from '../../data/contract-projects';
import { benchmarkSummary } from '../../data/benchmarks';

export function getStaticPaths() {
  return contractProjects.map((project) => ({ params: { slug: project.slug }, props: { project } }));
}

const { project } = Astro.props;
const index = contractProjects.findIndex((entry) => entry.slug === project.slug);
const previous = contractProjects[index - 1];
const next = contractProjects[index + 1];
const references = contractReferences(project);
---
<SiteLayout title={`${project.title} - Contract showcase`} description={project.description} active="contracts" theme={project.slug}>
  <div class="contract-theme-intro">
    <div class="page-frame contract-theme-intro-inner">
      <Badge variant="muted">{project.status} contract</Badge>
      <div class="palette-strip" aria-label="Contract palette">{project.palette.map((color) => <i style={`--swatch:${color}`}></i>)}</div>
      <code>{project.tone}</code>
    </div>
  </div>
  <div class="page-frame contract-detail-shell contract-project-shell">
    <aside class="contract-detail-sidebar project-sidebar">
      <a class="back-link" href="/contracts/"><Icon name="arrow" size={15} /> Back to contracts</a>
      <div class="detail-nav-label">Contract packs</div>
      <nav class="detail-nav" aria-label="Contract packs">
        {contractProjects.map((entry) => <a class:list={{ 'list-active': entry.slug === project.slug }} href={`/contracts/${entry.slug}/`}>{entry.shortTitle}</a>)}
      </nav>
      <div class="sidebar-command">
        <span>Install command</span>
        <code>{project.command}</code>
      </div>
      <a class="sidebar-doc-link" href="/docs/#workflow">How contracts work <Icon name="arrow" size={14} /></a>
    </aside>

    <article class="contract-project-detail">
      <div class="detail-breadcrumb"><a href="/contracts/">Contracts</a><span>/</span><span>{project.title}</span></div>
      <header class="project-hero">
        <div>
          <p class="eyebrow">Design project / {String(index + 1).padStart(2, '0')}</p>
          <h1>{project.title}</h1>
          <p>{project.description}</p>
          <div class="hero-contract-meta"><span>{project.skills.length} Skills</span><span>{project.files.length} project files</span><span>{project.photos.length} reference entries</span></div>
        </div>
        <div class="hero-contract-visual">
          <ContractPreview project={project} compact={true} />
          <div class="contract-folder-card" aria-label="Contract folder contents">
            <span>Project façade</span>
            <div>{project.files.slice(0, 4).map((file) => <code>{file}</code>)}</div>
          </div>
        </div>
      </header>

      <Surface as="section" class="prompt-panel" aria-labelledby="copy-prompt-title">
        <div>
          <p class="eyebrow">Primary handoff</p>
          <h2 id="copy-prompt-title">Give the AI the whole contract in one move.</h2>
          <p>Use the command or prompt to give the AI the contract, then let the installed Skills choose which design files, mappings, references, and component recipes apply.</p>
        </div>
        <Button class="copy-contract-prompt" dataCopy={project.prompt}>Copy AI prompt</Button>
        <pre><code>{project.prompt}</code></pre>
        <div class="command-ribbon"><span>Install / apply</span><code>{project.command}</code></div>
      </Surface>

      <section class="component-showcase" aria-labelledby="component-showcase-title">
        <p class="eyebrow">Rendered contract</p>
        <div class="section-heading-row">
          <h2 id="component-showcase-title">Same component vocabulary. A completely owned result.</h2>
          <p>Every contract can start from the same core primitives. The product identity comes from the Skills rewriting structure, spacing, color, state, and copy for that contract.</p>
        </div>
        <ContractDemo project={project} />
        <div class="component-contract-grid">
          {project.components.map((component) => (
            <Surface as="article">
              <span>{component.shadcnBase}</span>
              <h3>{component.name}</h3>
              <p>{component.intent}</p>
            </Surface>
          ))}
        </div>
      </section>

      <section class="contract-benchmark-panel" aria-labelledby="contract-benchmark-title">
        <div>
          <p class="eyebrow">Verification layer</p>
          <h2 id="contract-benchmark-title">Component fidelity is measured after generation.</h2>
          <p>The clean-room protocol hides the target component from the AI, gives each track only its allowed inputs, records prompt and manifest hashes, then scores the result. Five trained recipes now score {benchmarkSummary.trainedAverageScore}%, and the active approval-badge public holdout scored {benchmarkSummary.approvalBadgeHoldoutRun.score}%. That is the current benchmark evidence behind the 99% gate.</p>
        </div>
        <div class="benchmark-mini-grid">
          {benchmarkSummary.tracks.map((track) => (
            <article>
              <span>{track.label}</span>
              <strong>{track.score}%</strong>
              <p>{track.name}</p>
            </article>
          ))}
        </div>
        <div class="command-ribbon"><span>Clean-room prompt</span><code>{benchmarkSummary.cleanRoom.promptFile}</code></div>
        <div class="command-ribbon"><span>Release gate</span><code>{benchmarkSummary.releaseCommand}</code></div>
      </section>

      <section class="contract-evidence-grid" aria-label="Contract evidence">
        <article>
          <p class="eyebrow">Context anchors</p>
          <h2>What the Skill points at.</h2>
          <div class="file-list">{project.files.map((file) => <code>{file}</code>)}</div>
        </article>
        <article>
          <p class="eyebrow">Roles</p>
          <h2>Who owns judgment.</h2>
          <div class="pill-list">{project.roles.map((role) => <span>{role}</span>)}</div>
        </article>
        <article>
          <p class="eyebrow">Skill stack</p>
          <h2>Executable AI behavior.</h2>
          <div class="skill-card-list">{project.skills.map((skill) => <div><strong>{skill.name}</strong><code>{skill.path}</code><p><b>{skill.when}</b> · {skill.purpose}</p></div>)}</div>
        </article>
        <article>
          <p class="eyebrow">Reference memory</p>
          <h2>Photos and screenshots stay here.</h2>
          <div class="photo-reference-list">{project.photos.map((photo) => <div><strong>{photo.label}</strong><code>{photo.path}</code><p>{photo.note}</p></div>)}</div>
        </article>
      </section>

      <section class="source-reference-section" aria-labelledby="source-reference-title">
        <p class="eyebrow">Internal engine context</p>
        <h2 id="source-reference-title">The Skill compiles these behind the scenes.</h2>
        <div class="source-reference-list">
          {references.map((item) => (
            <a href={`https://github.com/byronwade/Design/blob/main/${item.source}`} target="_blank" rel="noreferrer">
              <span>{item.section}</span>
              <strong>{item.title}</strong>
              <small>{item.source}</small>
            </a>
          ))}
        </div>
      </section>

      <nav class="detail-pagination" aria-label="Adjacent contract packs">
        {previous ? <a href={`/contracts/${previous.slug}/`}><small>Previous</small><strong><Icon name="arrow" size={15} /> {previous.title}</strong></a> : <span></span>}
        {next ? <a class="next-topic" href={`/contracts/${next.slug}/`}><small>Next</small><strong>{next.title} <Icon name="arrow" size={15} /></strong></a> : <span></span>}
      </nav>
    </article>
  </div>
  <script>
    document.querySelector('.copy-contract-prompt')?.addEventListener('click', async (event) => {
      const button = event.currentTarget;
      await navigator.clipboard.writeText(button.dataset.copy);
      const original = button.textContent;
      button.textContent = 'Copied';
      setTimeout(() => { button.textContent = original; }, 1400);
    });
  </script>
</SiteLayout>
