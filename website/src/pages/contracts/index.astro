---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Icon from '../../components/Icon.astro';
import ContractPreview from '../../components/ContractPreview.astro';
import Badge from '../../components/ui/Badge.astro';
import SearchField from '../../components/ui/SearchField.astro';
import Surface from '../../components/ui/Surface.astro';
import Tabs from '../../components/ui/Tabs.astro';
import { contractProjects } from '../../data/contract-projects';
import { benchmarkSummary } from '../../data/benchmarks';
---
<SiteLayout title="Contracts - Design Contract" description="Browse AI-ready design contract packs with prompts, files, roles, skills, visual references, and component showcases." active="contracts">
  <section class="contracts-index contract-pack-index page-frame">
    <header class="contracts-index-head">
      <div class="contracts-heading-label"><Badge variant="muted">Contract library</Badge><Badge variant="success">{benchmarkSummary.approvalBadgeHoldoutRun.score}% verified holdout</Badge></div>
      <h1>Complete design control, ready for any AI.</h1>
      <div class="contracts-head-bottom">
        <p>Each pack combines the one-file grammar, universal Skill, task prompt, component translation rules, optional visual memory, checks, and verification receipt. Open one to inspect the files and the interface it produces.</p>
      </div>
    </header>

    <div class="contract-system-strip" aria-label="Contract workflow">
      <article><span>01</span><strong>Understand</strong><p>Intent, risk, and state.</p></article>
      <article><span>02</span><strong>Resolve</strong><p>Only the task packet.</p></article>
      <article><span>03</span><strong>Check</strong><p>Source drift blocked.</p></article>
      <article><span>04</span><strong>Verify</strong><p>Receipt before approval.</p></article>
    </div>

    <div class="contracts-toolbar">
      <SearchField id="contract-search" placeholder="Search contracts, Skills, or components" />
      <Tabs class="contract-section-tabs" label="Contract filters">
        <a class="is-selected" role="tab" href="/contracts/" data-filter-section="All">All</a>
        <a role="tab" href="/contracts/?section=Ready" data-filter-section="Ready">Ready</a>
        <a role="tab" href="/contracts/?section=Example" data-filter-section="Example">Example</a>
        <a role="tab" href="/contracts/?section=Draft" data-filter-section="Draft">Draft</a>
      </Tabs>
      <span id="contract-result-count" class="result-count">{contractProjects.length} packs</span>
    </div>

    <div class="contract-grid contract-pack-grid" id="contract-grid">
      {contractProjects.map((project) => (
        <Surface as="a" class="contract-card contract-pack-card" href={`/contracts/${project.slug}/`} data-contract-section={project.status} data-search={`${project.title} ${project.tone} ${project.description} ${project.command} ${project.files.join(' ')} ${project.skills.map((skill) => `${skill.name} ${skill.purpose}`).join(' ')}`}>
          <ContractPreview project={project} />
          <div class="contract-card-meta"><span>{project.status} / {project.tone}</span><Icon name="arrow" size={16} /></div>
          <h2>{project.title}</h2>
          <p>{project.description}</p>
          <div class="pack-card-foot"><span>{project.files.length} files</span><span>{project.skills.length} Skills</span><span>{project.photos.length} references</span></div>
        </Surface>
      ))}
    </div>
    <p id="contract-empty" class="empty-results" hidden>No contract packs match that search.</p>

    <section class="contracts-benchmark-strip">
      <div>
        <span>Clean-room benchmark</span>
        <strong>The current public gate is met for the active holdout.</strong>
        <p>Fidelity is scored across {benchmarkSummary.metrics.join(', ')}. Historical misses remain visible in the benchmark documentation.</p>
      </div>
      <code>{benchmarkSummary.command}</code>
      <a class="text-link" href="/docs/#benchmarks">Method <Icon name="arrow" size={14} /></a>
    </section>
  </section>
  <script>
    const search = document.querySelector('#contract-search');
    const cards = [...document.querySelectorAll('.contract-card')];
    const grid = document.querySelector('#contract-grid');
    const resultCount = document.querySelector('#contract-result-count');
    const empty = document.querySelector('#contract-empty');
    const tabs = [...document.querySelectorAll('.contract-section-tabs [data-filter-section]')];
    const params = new URLSearchParams(window.location.search);
    let activeSection = params.get('section') || 'All';
    const update = () => {
      const query = search.value.trim().toLowerCase();
      let visible = 0;
      cards.forEach((card) => {
        const show = (!query || card.dataset.search.toLowerCase().includes(query)) && (activeSection === 'All' || card.dataset.contractSection === activeSection);
        card.hidden = !show;
        if (show) visible += 1;
      });
      resultCount.textContent = `${visible} ${visible === 1 ? 'pack' : 'packs'}`;
      empty.hidden = visible !== 0;
      grid.classList.toggle('is-single-result', visible === 1);
      tabs.forEach((tab) => {
        const selected = tab.dataset.filterSection === activeSection;
        tab.classList.toggle('is-selected', selected);
        tab.setAttribute('aria-selected', String(selected));
      });
    };
    tabs.forEach((tab) => tab.addEventListener('click', (event) => {
      event.preventDefault();
      activeSection = tab.dataset.filterSection;
      history.replaceState({}, '', activeSection === 'All' ? '/contracts/' : `?section=${encodeURIComponent(activeSection)}`);
      update();
    }));
    search.addEventListener('input', update);
    document.addEventListener('keydown', (event) => {
      if (event.key === '/' && document.activeElement !== search) {
        event.preventDefault();
        search.focus();
      }
    });
    update();
  </script>
</SiteLayout>
