---
import SiteLayout from '../layouts/SiteLayout.astro';
import Icon from '../components/Icon.astro';
import { evaluationCommands, qualityChecks } from '../data/system';
---
<SiteLayout title="Evaluation — Design / index" description="The browser and package quality gates for the Design Contract reference surface.">
  <section class="evaluate-hero page-frame"><p class="eyebrow"><span class="eyebrow-rule"></span> Quality / evidence</p><h1>Quality is a route,<br /><em>not a footnote.</em></h1><p>This page documents what the official surface proves, what it cannot prove on its own, and the commands that close the loop from source to browser.</p></section>
  <section class="evaluate-layout page-frame"><aside class="evaluate-aside"><span>Evaluation map</span><a href="#checks">Checks</a><a href="#commands">Commands</a><a href="#limits">Limits</a></aside><div class="evaluate-content"><section id="checks"><div class="section-heading"><div><p class="eyebrow"><span class="eyebrow-rule"></span> Browser contract</p><h2>Visible gates.</h2></div><span class="pass-summary"><i></i> {qualityChecks.length} passing</span></div><div class="quality-list">{qualityChecks.map((check) => <article class="quality-row"><span class="quality-id">{check.id}</span><div><h3>{check.title}</h3><p>{check.description}</p></div><div class="quality-evidence"><span>{check.evidence}</span><strong><i></i>{check.status}</strong></div></article>)}</div></section><section id="commands" class="command-section"><p class="eyebrow"><span class="eyebrow-rule"></span> Reproduce it</p><h2>The commands that close the loop.</h2><div class="evaluation-commands">{evaluationCommands.map((item) => <div class="eval-command"><span>{item.label}</span><code>{item.command}</code><button class="copy-command" data-copy={item.command} type="button" aria-label={`Copy ${item.command}`}><Icon name="check" size={14} /></button></div>)}</div></section><section id="limits" class="limits-section"><p class="eyebrow"><span class="eyebrow-rule"></span> Be precise</p><h2>What this surface does not claim.</h2><div class="limits-grid"><p><strong>Static output is not runtime proof.</strong> A successful build proves route generation and type integrity. It does not prove every viewport, browser, device, or assistive technology path.</p><p><strong>A token is not a mapping.</strong> The Lab shows the contract. Production projects still map intent to real components, stories, and tests in their own context.</p></div></section></div></section>
  <script>
    document.querySelectorAll('[data-copy]').forEach((button) => button.addEventListener('click', async () => { await navigator.clipboard.writeText(button.dataset.copy); button.classList.add('is-copied'); setTimeout(() => button.classList.remove('is-copied'), 1200); }));
  </script>
</SiteLayout>
