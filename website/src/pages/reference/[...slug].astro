---
import { fileURLToPath } from 'node:url';
import { dirname, resolve } from 'node:path';
import { readFileSync } from 'node:fs';
import SiteLayout from '../../layouts/SiteLayout.astro';
import Icon from '../../components/Icon.astro';
import { reference } from '../../data/reference';
import { markdownToHtml } from '../../lib/markdown';

const repoRoot = resolve(dirname(fileURLToPath(import.meta.url)), '../../../..');
export function getStaticPaths() { return reference.map((item) => ({ params: { slug: item.slug }, props: { item } })); }
const { item } = Astro.props;
const index = reference.findIndex((entry) => entry.slug === item.slug);
const previous = reference[index - 1];
const next = reference[index + 1];
const sourceText = readFileSync(resolve(repoRoot, item.source), 'utf8');
const sourceHtml = markdownToHtml(item.format === 'json' ? `\`\`\`json\n${sourceText}\n\`\`\`` : sourceText);
const sectionItems = reference.filter((entry) => entry.section === item.section);
---
<SiteLayout title={`${item.title} — Reference / Design index`} description={item.description} active="docs">
  <div class="reference-detail-shell page-frame"><aside class="reference-detail-sidebar"><a class="back-link" href="/reference/"><Icon name="arrow" size={15} /> Back to reference</a><div class="detail-nav-label">{item.section}</div><nav class="detail-nav" aria-label={`${item.section} reference documents`}>{sectionItems.map((entry) => <a class:list={{ 'list-active': entry.slug === item.slug }} href={`/reference/${entry.slug}/`}>{entry.title}</a>)}</nav><a class="detail-doc-link" href="/docs/">How to read the system <Icon name="arrow" size={14} /></a></aside><article class="reference-reader"><div class="detail-breadcrumb"><a href="/reference/">Reference</a><span>/</span><span>{item.section}</span><span>/</span><span>{item.title}</span></div><header class="reference-detail-header"><p class="eyebrow"><span class="eyebrow-rule"></span> {item.section}</p><h1>{item.title}</h1><p>{item.description}</p><div class="reference-detail-meta"><span class={`status status-${item.status.toLowerCase()}`}>{item.status}</span><code>{item.source}</code></div></header><div class="detail-rule"></div><div class="reference-reader-layout"><div class="reference-prose" set:html={sourceHtml}></div><aside class="reference-source-aside"><span class="eyebrow">SOURCE</span><p>This page is rendered from the local contract. The source file remains authoritative.</p><a class="text-link" href={`https://github.com/byronwade/Design/blob/main/${item.source}`} target="_blank" rel="noreferrer">Open on GitHub <Icon name="external" size={14} /></a></aside></div><nav class="detail-pagination" aria-label="Adjacent reference documents">{previous ? <a href={`/reference/${previous.slug}/`}><small>Previous</small><strong><Icon name="arrow" size={15} /> {previous.title}</strong></a> : <span></span>}{next ? <a class="next-topic" href={`/reference/${next.slug}/`}><small>Next</small><strong>{next.title} <Icon name="arrow" size={15} /></strong></a> : <span></span>}</nav></article></div>
</SiteLayout>
