---
import SiteLayout from '../layouts/SiteLayout.astro';
import Icon from '../components/Icon.astro';
import CatalogCard from '../components/CatalogCard.astro';
import { catalog } from '../data/catalog';

const blocks = catalog.filter((item) => item.group === 'Patterns');
---

<SiteLayout title="Blocks — Design Contract" description="Reusable shells, pages, flows, and states for composing product surfaces from the design contract." active="blocks">
  <div class="docs-page-shell page-frame">
    <aside class="docs-sidebar" aria-label="Blocks navigation">
      <div class="docs-sidebar-section"><span>Blocks</span><a class="is-active" href="/blocks/">All blocks <small>{blocks.length}</small></a><a href="/catalog/?group=Patterns">Patterns <small>{blocks.length}</small></a></div>
      <div class="docs-sidebar-section"><span>Compose</span><a href="/catalog/?group=Components">Components</a><a href="/docs/#workflow">App recipes</a><a href="/docs/#verify">Quality gates</a></div>
      <div class="docs-sidebar-note"><span class="note-dot"></span><p>Blocks are approved compositions. They still inherit tokens, intent, and accessibility rules from the contract.</p></div>
    </aside>
    <main class="docs-page-content">
      <header class="docs-page-header"><p class="eyebrow"><span class="eyebrow-rule"></span> Reusable compositions</p><h1>Blocks</h1><p>Product-ready shells, page patterns, flows, and states for building on top of shadcn/ui primitives without losing the product point of view.</p><div class="docs-header-actions"><a class="button button-primary" href="/docs/#install">Add the contract <Icon name="arrow" size={15} /></a><a class="text-link" href="/catalog/?group=Patterns">Read patterns <Icon name="arrow" size={15} /></a></div></header>
      <div class="docs-inline-note"><span class="note-dot"></span><p>Reuse a block before creating a new page-local composition. If the capability is missing, record the design-system gap.</p></div>
      <div class="catalog-grid blocks-grid">{blocks.map((item) => <CatalogCard item={item} />)}</div>
    </main>
  </div>
</SiteLayout>
