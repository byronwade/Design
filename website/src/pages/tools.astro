---
import SiteLayout from '../layouts/SiteLayout.astro';
import Icon from '../components/Icon.astro';
import { toolingCommands, toolingProfiles } from '../data/system';
---
<SiteLayout title="Toolbox — Design / index" description="The authoring toolbox for choosing profiles, compiling context, inspecting rules, and validating a design contract." active="tools">
  <section class="tools-hero page-frame"><p class="eyebrow"><span class="eyebrow-rule"></span> For builders and agents</p><h1>The toolbox<br /><em>behind the surface.</em></h1><p>Choose one of {toolingProfiles.length} supported targets, compile only the context you need, inspect the rule behind a decision, and validate the result before it reaches production.</p><a class="button button-primary" href="https://github.com/byronwade/Design#commands" target="_blank" rel="noreferrer">Open CLI reference <Icon name="external" size={15} /></a></section>
  <section class="tools-layout page-frame"><aside class="tools-toc"><span>Toolbox</span><a href="#profiles">Profiles</a><a href="#flow">Authoring flow</a><a href="#ownership">Ownership</a></aside><div class="tools-body"><section id="profiles"><p class="eyebrow"><span class="eyebrow-rule"></span> Start with a surface</p><h2>Profiles keep context honest.</h2><p>Select the product surface before you write a new rule. Sibling platforms are not silently mixed.</p><div class="profile-grid">{toolingProfiles.map((profile) => <article class="profile-card"><div><div class="profile-card-top"><code>{profile.name}</code><span>{profile.family}</span></div><h3>{profile.title}</h3><p>{profile.description}</p></div><small>{profile.layers}<br />{profile.composite ? 'composite target' : 'single family'} · {profile.roots.join(' + ')}</small></article>)}</div></section><section id="flow" class="tools-flow"><p class="eyebrow"><span class="eyebrow-rule"></span> The authoring flow</p><h2>Four verbs from idea to evidence.</h2><div class="tool-command-list">{toolingCommands.map((tool) => <article><span>{tool.step}</span><div><h3>{tool.title}</h3><code>{tool.command}</code><p>{tool.description}</p></div></article>)}</div></section><section id="ownership" class="ownership-section"><p class="eyebrow"><span class="eyebrow-rule"></span> Keep the boundary clear</p><h2>Projects own identity.<br />The package owns reasoning.</h2><div class="ownership-grid"><p><strong>Project-owned</strong><br /><code>DESIGN.md</code>, product context, component mappings, decisions, and production evidence.</p><p><strong>Package-owned</strong><br />Shared principles, platform overlays, quality rules, schemas, adapters, and compiler behavior.</p></div><a class="text-link" href="/docs/">Read the documentation <Icon name="arrow" size={15} /></a></section></div></section>
</SiteLayout>
