---
import SiteLayout from '../layouts/SiteLayout.astro';
import Icon from '../components/Icon.astro';
import CatalogCard from '../components/CatalogCard.astro';
import { catalog, featured, groups } from '../data/catalog';
---
<SiteLayout title="Design Contract — Components, blocks, and rules" description="An open design contract for building consistent products with shadcn/ui components, reusable blocks, and inspectable decisions." active="home">
  <section class="hero page-frame"><div class="hero-copy"><a class="hero-announcement" href="/docs/"><span class="announcement-dot"></span> Design Contract 1.2 <Icon name="arrow" size={13} /></a><h1>Build on a<br /><span>living contract.</span></h1><p class="hero-lede">A shadcn/ui-inspired reference surface for components, blocks, app recipes, and the decisions that keep every product surface consistent.</p><div class="hero-actions"><a class="button button-primary" href="/docs/">Get started <Icon name="arrow" size={16} /></a><a class="text-link" href="/catalog/">Browse components <Icon name="arrow" size={15} /></a></div><div class="hero-command"><span>$</span><code>npx --yes github:byronwade/Design init --profile web-app</code></div></div></section>
  <section class="index-strip page-frame" aria-label="Index summary"><div><strong>{catalog.length}</strong><span>topics in the catalog</span></div><div><strong>{groups.length}</strong><span>connected layers</span></div><div><strong>0</strong><span>client dependencies</span></div><div class="strip-note">Every entry links back to a versioned source in the repository.</div></section>
  <section class="home-section page-frame"><div class="section-heading"><div><p class="eyebrow"><span class="eyebrow-rule"></span> Start here</p><h2>Components you can build on.</h2></div><a class="text-link" href="/catalog/">View all components <Icon name="arrow" size={15} /></a></div><div class="catalog-grid featured-grid">{featured.map((item) => <CatalogCard item={item} />)}</div></section>
  <section class="layer-section page-frame"><div class="section-heading"><div><p class="eyebrow"><span class="eyebrow-rule"></span> Compose with intent</p><h2>From primitives to product surfaces.</h2></div><p class="section-intro">Use foundations, components, blocks, recipes, and quality rules as one connected system. The AI gets the same map every time.</p></div><div class="layer-list">{groups.map((group, index) => <a href={`/catalog/?group=${encodeURIComponent(group.name)}`} class="layer-row"><span class="layer-index">0{index + 1}</span><span class="layer-name">{group.name}</span><span class="layer-description">{group.description}</span><span class="layer-count">{group.count} topics <Icon name="arrow" size={15} /></span></a>)}</div></section>
  <section class="cta-band page-frame"><div><p class="eyebrow"><span class="eyebrow-rule"></span> Open source, locally owned</p><h2>Make the system<br />your own.</h2></div><div class="hero-actions"><a class="button button-secondary" href="/blocks/">Explore blocks <Icon name="arrow" size={15} /></a><a class="text-link" href="https://github.com/byronwade/Design" target="_blank" rel="noreferrer">View source <Icon name="github" size={16} /></a></div></section>
</SiteLayout>
