---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Icon from '../../components/Icon.astro';
import CatalogPreview from '../../components/CatalogPreview.astro';
import { catalog } from '../../data/catalog';
export function getStaticPaths() { return catalog.map((item) => ({ params: { slug: item.slug }, props: { item } })); }
const { item } = Astro.props;
const index = catalog.findIndex((entry) => entry.slug === item.slug);
const previous = catalog[index - 1];
const next = catalog[index + 1];
---
<SiteLayout title={`${item.title} — Design / index`} description={item.description} active="catalog"><div class="detail-shell page-frame"><aside class="detail-sidebar"><a class="back-link" href="/catalog/"><Icon name="arrow" size={15} /> Back to catalog</a><div class="detail-nav-label">{item.group}</div><nav class="detail-nav" aria-label={`${item.group} topics`}>{catalog.filter((entry) => entry.group === item.group).map((entry) => <a class:list={{ 'list-active': entry.slug === item.slug }} href={`/catalog/${entry.slug}/`}>{entry.title}</a>)}</nav><a class="detail-doc-link" href="/docs/">How to use this index <Icon name="arrow" size={14} /></a></aside><article class="detail-content"><div class="detail-breadcrumb"><a href="/catalog/">Catalog</a><span>/</span><span>{item.group}</span><span>/</span><span>{item.title}</span></div><header class="detail-header"><p class="eyebrow"><span class="eyebrow-rule"></span> {item.eyebrow}</p><h1>{item.title}</h1><p class="detail-lede">{item.description}</p><div class="detail-tags">{item.tags.map((tag) => <span>{tag}</span>)}</div></header><div class="detail-rule"></div><section class="detail-specimen"><div class="detail-section-label"><span>SPECIMEN</span><span>{item.source}</span></div><CatalogPreview type={item.preview} /></section><section class="principle-section"><div class="detail-section-label"><span>CONTRACT</span><span>{item.principles.length} principles</span></div><div class="principle-list">{item.principles.map((principle, i) => <div class="principle-row"><span>0{i + 1}</span><p>{principle}</p><Icon name="check" size={16} /></div>)}</div></section><section class="source-section"><div><p class="eyebrow"><span class="eyebrow-rule"></span> Source of truth</p><h2>Read the rule in context.</h2><p>The site is a rendered index, not a second editable system. This entry points back to the versioned contract that owns the decision.</p></div><a class="button button-secondary" href={`https://github.com/byronwade/Design/blob/main/${item.source}`} target="_blank" rel="noreferrer">Open on GitHub <Icon name="external" size={15} /></a></section><nav class="detail-pagination" aria-label="Adjacent topics">{previous ? <a href={`/catalog/${previous.slug}/`}><small>Previous</small><strong><Icon name="arrow" size={15} /> {previous.title}</strong></a> : <span></span>}{next ? <a class="next-topic" href={`/catalog/${next.slug}/`}><small>Next</small><strong>{next.title} <Icon name="arrow" size={15} /></strong></a> : <span></span>}</nav></article></div></SiteLayout>
