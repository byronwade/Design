---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Icon from '../../components/Icon.astro';
import CatalogCard from '../../components/CatalogCard.astro';
import { catalog, groups } from '../../data/catalog';
---
<SiteLayout title="Catalog — Design / index" description="Browse the design contract by foundation, structure, component, pattern, and quality topic." active="catalog">
  <div class="catalog-shell page-frame"><aside class="catalog-sidebar" aria-label="Catalog filters"><div class="sidebar-heading"><span class="eyebrow">INDEX</span><span class="sidebar-total">{catalog.length} topics</span></div><nav class="sidebar-nav"><a class="sidebar-link is-selected" href="/catalog/" data-group="All">All topics <span>{catalog.length}</span></a>{groups.map((group) => <a class="sidebar-link" href={`/catalog/?group=${encodeURIComponent(group.name)}`} data-group={group.name}>{group.name} <span>{group.count}</span></a>)}</nav><div class="sidebar-note"><span class="note-dot"></span><p>Everything here is local, versioned, and written to be read by people and agents.</p></div></aside><section class="catalog-content"><div class="catalog-heading"><div><p class="eyebrow"><span class="eyebrow-rule"></span> Browse the system</p><h1>A library for the<br /><em>whole</em> interface.</h1></div><p class="catalog-heading-copy">Not just components. The decisions around them, from the first color role to the last quality gate.</p></div><div class="catalog-toolbar"><label class="search-field"><Icon name="search" size={17} /><input id="catalog-search" type="search" placeholder="Search topics, rules, or tags" autocomplete="off" /><kbd>/</kbd></label><span id="result-count" class="result-count">{catalog.length} topics</span></div><div class="catalog-grid" id="catalog-grid">{catalog.map((item) => <CatalogCard item={item} />)}</div><p id="empty-results" class="empty-results" hidden>No topics match that search. Try a broader term.</p></section></div>
  <script>
    const search = document.querySelector('#catalog-search');
    const cards = [...document.querySelectorAll('[data-search]')];
    const resultCount = document.querySelector('#result-count');
    const emptyResults = document.querySelector('#empty-results');
    const links = [...document.querySelectorAll('[data-group]')];
    const params = new URLSearchParams(window.location.search);
    let activeGroup = params.get('group') || 'All';
    const update = () => { const query = search.value.trim().toLowerCase(); let visible = 0; cards.forEach((card) => { const matchesQuery = !query || card.dataset.search.toLowerCase().includes(query); const matchesGroup = activeGroup === 'All' || card.dataset.search.includes(activeGroup); const show = matchesQuery && matchesGroup; card.hidden = !show; if (show) visible += 1; }); resultCount.textContent = `${visible} ${visible === 1 ? 'topic' : 'topics'}`; emptyResults.hidden = visible !== 0; links.forEach((link) => link.classList.toggle('is-selected', link.dataset.group === activeGroup)); };
    links.forEach((link) => link.addEventListener('click', (event) => { event.preventDefault(); activeGroup = link.dataset.group; history.replaceState({}, '', activeGroup === 'All' ? '/catalog/' : `/catalog/?group=${encodeURIComponent(activeGroup)}`); update(); }));
    search.addEventListener('input', update); update();
  </script>
</SiteLayout>
