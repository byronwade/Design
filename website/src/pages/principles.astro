---
import SiteLayout from '../layouts/SiteLayout.astro';
import Icon from '../components/Icon.astro';
const principles = [['01', 'A system is a point of view.', 'Tokens are only useful when they carry a clear opinion about hierarchy, material, and attention.'], ['02', 'Structure before decoration.', 'A region’s placement, density, and scroll behavior should explain what it owns before color or elevation enters the room.'], ['03', 'The contract is for people and agents.', 'Rules should be concrete enough to guide implementation, and readable enough to invite judgment rather than hide it.'], ['04', 'Evidence closes the loop.', 'A design decision becomes trustworthy when its source, production mapping, and rendered behavior can be inspected together.']];
---
<SiteLayout title="Principles — Design / index" description="The principles behind an open, inspectable design contract." active="principles"><section class="principles-hero page-frame"><div><p class="eyebrow"><span class="eyebrow-rule"></span> The point of view</p><h1>Build the thing<br /><em>you can explain.</em></h1></div><p class="principles-intro">Good systems do more than make screens look related. They make decisions legible, reusable, and testable across surfaces.</p></section><section class="principles-list page-frame">{principles.map(([number, title, copy]) => <article class="principle-card"><span>{number}</span><div><h2>{title}</h2><p>{copy}</p></div><Icon name="arrow" size={18} /></article>)}</section><section class="principles-bottom page-frame"><div><p class="eyebrow"><span class="eyebrow-rule"></span> Keep going</p><h2>See how the contract<br />becomes a working surface.</h2></div><a class="button button-primary" href="/docs/">Read the docs <Icon name="arrow" size={16} /></a></section></SiteLayout>
