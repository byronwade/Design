---
import Icon from './Icon.astro';
import ShowcasePreview from './ShowcasePreview.astro';
const { screens } = Astro.props;
---
<section class="showcase-gallery" aria-labelledby="showcase-gallery-heading">
  <div class="showcase-gallery-heading">
    <div>
      <p class="eyebrow"><span class="eyebrow-rule"></span> Surface study</p>
      <h2 id="showcase-gallery-heading">The system, in context.</h2>
    </div>
    <span class="showcase-gallery-count"><Icon name="layers" size={14} /> {screens.length} local screens</span>
  </div>
  <div class="showcase-screen-grid">
    {screens.map((screen, index) => <figure class:list={["showcase-screen", { "showcase-screen-feature": index === 0 }]}>
      <div class="showcase-screen-frame">
        {screen.asset ? <img src={screen.asset} alt={screen.alt ?? `${screen.title} screen`} loading={index === 0 ? 'eager' : 'lazy'} decoding="async" /> : <ShowcasePreview type={screen.preview} gallery={true} />}
      </div>
      <figcaption class="showcase-screen-caption"><span>{screen.label}</span><div><strong>{screen.title}</strong><p>{screen.caption}</p></div></figcaption>
    </figure>)}
  </div>
</section>
