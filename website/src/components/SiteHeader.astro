---
import Badge from './ui/Badge.astro';
import Button from './ui/Button.astro';
import { contractProjects } from '../data/contract-projects';
const { active = '' } = Astro.props;
---
<header class="site-header">
  <div class="header-inner">
    <a class="wordmark" href="/" aria-label="Design Contract home">
      <span class="wordmark-mark" aria-hidden="true"><i></i><i></i><i></i></span>
      <span>Design Contract</span>
      <Badge variant="muted">Open source</Badge>
    </a>
    <nav class="main-nav" aria-label="Primary navigation">
      <a class:list={{ 'list-active': active === 'home' }} href="/">Home</a>
      <a class:list={{ 'list-active': active === 'contracts' }} href="/contracts/">Contracts <span>{contractProjects.length}</span></a>
      <a class:list={{ 'list-active': active === 'docs' }} href="/docs/">Docs</a>
    </nav>
    <div class="header-actions">
      <Button href="/contracts/" variant="ghost" size="sm" icon="search" ariaLabel="Search contracts"><span class="header-search-label">Search</span></Button>
      <Button href="https://github.com/byronwade/Design" variant="outline" size="sm" icon="github" target="_blank" rel="noreferrer" ariaLabel="Open GitHub repository">GitHub</Button>
    </div>
  </div>
</header>
